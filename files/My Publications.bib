@article{arnoldLatentClassAnalysis2025,
  title = {Latent Class Analysis Identifies Risk Groups to Model the Expected Benefits of {{SARS-CoV-2}} Interventions among University Students},
  author = {Arnold, Callum and Bharti, Nita and Exten, Cara and Small, Meg and Srinivasan, Sreenidhi and Kuchipudi, Suresh V. and Kapur, Vivek and Ferrari, Matthew J.},
  date = {2025-04-02},
  journaltitle = {Scientific Reports},
  shortjournal = {Sci Rep},
  volume = {15},
  number = {1},
  pages = {11199},
  publisher = {Nature Publishing Group},
  issn = {2045-2322},
  doi = {10.1038/s41598-025-95164-x},
  url = {https://www.nature.com/articles/s41598-025-95164-x},
  urldate = {2025-04-02},
  abstract = {Non-pharmaceutical public health measures (PHMs) were central to pre-vaccination efforts to reduce Severe Acute Respiratory Syndrome Coronavirus 2 (SARS-CoV-2) exposure risk; heterogeneity in adherence placed bounds on their potential effectiveness, and correlation in their adoption makes assessing the impact attributable to an individual PHM difficult. During the Fall 2020 semester, we used a longitudinal cohort design in a university student population to conduct a behavioral survey of intention to adhere to PHMs, paired with an IgG serosurvey to quantify SARS-CoV-2 exposure at the end of the semester. Using latent class analysis on behavioral survey responses, we identified three distinct groups among the 673 students with IgG samples: 256 (38.04\%) students were in the most adherent group, intending to follow all guidelines, 306 (46.21\%) in the moderately-adherent group, and 111 (15.75\%) in the least-adherent group, rarely intending to follow any measure, with adherence negatively correlated with seropositivity of 25.4\%, 32.2\% and 37.7\%, respectively. Moving all individuals in an SIR model into the most adherent group resulted in a 77–96\% reduction in seroprevalence, dependent on assumed assortativity. The potential impact of increasing PHM adherence was limited by the substantial exposure risk in the large proportion of students already following all PHMs.},
  langid = {english},
  keywords = {Computational models,Viral infection},
  file = {/Volumes/External4TB/Documents/Repos/Notes/attachments/literature-notes/arnoldLatentClassAnalysis2025/@arnoldLatentClassAnalysis2025.pdf}
}

@article{arnoldLongitudinalStudyImpact2022,
  title = {A Longitudinal Study of the Impact of University Student Return to Campus on the {{SARS-CoV-2}} Seroprevalence among the Community Members},
  author = {Arnold, Callum and Srinivasan, Sreenidhi and Rodriguez, Sophie and Rydzak, Natalie and Herzog, Catherine M. and Gontu, Abhinay and Bharti, Nita and Small, Meg and Rogers, Connie J. and Schade, Margeaux M. and Kuchipudi, Suresh V. and Kapur, Vivek and Read, Andrew F. and Ferrari, Matthew J.},
  date = {2022-05-21},
  journaltitle = {Scientific Reports},
  shortjournal = {Scientific Reports},
  volume = {12},
  number = {1},
  pages = {8586},
  publisher = {Nature Publishing Group},
  issn = {2045-2322},
  doi = {10.1038/s41598-022-12499-5},
  url = {https://www.nature.com/articles/s41598-022-12499-5},
  urldate = {2023-01-17},
  abstract = {Returning university students represent large-scale, transient demographic shifts and a potential source of transmission to adjacent communities during the COVID-19 pandemic. In this prospective longitudinal cohort study, we tested for IgG antibodies against SARS-CoV-2 in a non-random cohort of residents living in Centre County prior to the Fall 2020 term at the Pennsylvania State University and following the conclusion of the Fall 2020 term. We also report the seroprevalence in a non-random cohort of students collected at the end of the Fall 2020 term. Of 1313 community participants, 42 (3.2\%) were positive for SARS-CoV-2 IgG antibodies at their first visit between 07 August and 02 October 2020. Of 684 student participants who returned to campus for fall instruction, 208 (30.4\%) were positive for SARS-CoV-2 antibodies between 26 October and 21 December. 96 (7.3\%) community participants returned a positive IgG antibody result by 19 February. Only contact with known SARS-CoV-2-positive individuals and attendance at small gatherings (20–50 individuals) were significant predictors of detecting IgG antibodies among returning students (aOR, 95\% CI 3.1, 2.07–4.64; 1.52, 1.03–2.24; respectively). Despite high seroprevalence observed within the student population, seroprevalence in a longitudinal cohort of community residents was low and stable from before student arrival for the Fall 2020 term to after student departure. The study implies that heterogeneity in SARS-CoV-2 transmission can occur in geographically coincident populations.},
  issue = {1},
  langid = {english},
  keywords = {Epidemiology,Viral infection},
  file = {/Volumes/External4TB/Documents/Repos/Notes/attachments/literature-notes/arnoldLongitudinalStudyImpact2022/@arnoldLongitudinalStudyImpact2022.pdf}
}

@unpublished{arnoldMaximalExpectedBenefit2023,
  type = {Poster},
  title = {The {{Maximal Expected Benefit}} of {{SARS-CoV-2 Intervention Among University Students}}: {{A Simulation Study Using Latent Class Analysis}}},
  author = {Arnold, Callum and Ferrari, Matthew J},
  date = {2023-05-24},
  url = {https://osf.io/qbtfs/},
  abstract = {Introduction In late 2020, we observed vastly different SARS-CoV-2 seroprevalences within two geographically coincident populations: community residents and University students returning for the Fall semester. Adherence to public health guidelines varied drastically within the student population, intimating there was heterogeneity in their risk tolerance, and therefore exposure to SARS-CoV-2. We identify groups of students by their behavioral responses, and simulate the maximal expected impact of non-pharmaceutical interventions (NPIs) on transmission reduction, using empirical data to bound the results. Methods We performed Latent Class Analysis (LCA) to identify the number of subgroups (latent classes) among the student population, separated by their behavioral survey responses to public health adherence questions, before calculating the seroprevalences for each of the latent classes. We then parameterized an SIR model using Approximate Bayesian Computation (ABC), with the latent class seroprevalences as the target statistic. Modifying the relative latent class sizes illustrates the expected benefit of an intervention that increases the adherence to NPIs. Results/Discussion A three-class LCA model best fit the behavioral responses of the 673 individuals with both survey answers and IgG samples. 256 (38.0\%) students were in the most adherent class, intending to follow all NPIs, 306 (45.5\%) in the moderately-adherent class, and 111 (16.5\%) in the least-adherent class, rarely intending to follow any public health measure. Moving all students to the most adherent class resulted in a 60\% reduction in seroprevalence. Despite best efforts, NPIs are not perfectly efficacious in transmission reduction. We demonstrate the maximal expected benefit through NPIs alone, highlighting the need for additional measures in outbreak situations.},
  eventtitle = {{{EEID}} 2023},
  venue = {State College, USA}
}

